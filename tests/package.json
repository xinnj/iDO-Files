{
  "name": "ido-files-e2e-tests",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:chromium": "playwright test --project=chromium",
    "test:edge": "playwright test --project=edge",
    "test:webkit": "playwright test --project=webkit",
    "report": "playwright show-report",
    "codegen": "playwright codegen",
    "server:start": "bash env/start.sh",
    "server:stop": "bash env/stop.sh",
    "e2e": "bash env/start.sh && playwright test && bash env/stop.sh",
    "install:browsers": "playwright install --with-deps chromium && playwright install --with-deps msedge && playwright install --with-deps webkit"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0"
  }
}
